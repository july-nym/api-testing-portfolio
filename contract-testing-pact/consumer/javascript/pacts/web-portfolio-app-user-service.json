{
  "consumer": {
    "name": "web-portfolio-app"
  },
  "interactions": [
    {
      "description": "a request for user 2",
      "providerStates": [
        {
          "name": "user 2 exists"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/users/2"
      },
      "response": {
        "body": {
          "data": {
            "email": "janet.weaver@example.com",
            "first_name": "Janet",
            "id": 2
          }
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.data.email": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$"
                }
              ]
            },
            "$.data.first_name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            }
          },
          "header": {},
          "status": {}
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "12.5.2"
    },
    "pactRust": {
      "ffi": "0.4.20",
      "models": "1.2.0"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "user-service"
  }
}