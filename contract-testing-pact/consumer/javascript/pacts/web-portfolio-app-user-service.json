{
  "consumer": {
    "name": "web-portfolio-app"
  },
  "provider": {
    "name": "user-service"
  },
  "interactions": [
    {
      "description": "a request for user 2",
      "providerStates": [
        {
          "name": "user 2 exists"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/users/2"
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "data": {
            "id": 2,
            "email": "janet.weaver@reqres.in",
            "first_name": "Janet"
          }
        },
        "matchingRules": {
          "body": {
            "$.data.id": {
              "matchers": [{ "match": "integer" }],
              "combine": "AND"
            },
            "$.data.email": {
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$"
                }
              ],
              "combine": "AND"
            },
            "$.data.first_name": {
              "matchers": [{ "match": "type" }],
              "combine": "AND"
            }
          }
        }
      }
    }
  ],
  "metadata": {
    "pactSpecification": {
      "version": "3.0.0"
    },
    "comment": "Checked-in sample. Re-generated by `npm run test:pact` in consumer/javascript."
  }
}
