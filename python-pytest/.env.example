# Copy to .env and adjust as needed. Sensible public-sandbox defaults are baked
# into config/settings.py, so the suite runs without this file — it's here for
# when you point the tests at a different environment.

REQRES_BASE_URL=https://reqres.in/api
# reqres gates writes behind a free key; "reqres-free-v1" works for the sandbox.
REQRES_API_KEY=reqres-free-v1

JSONPLACEHOLDER_BASE_URL=https://jsonplaceholder.typicode.com

BOOKER_BASE_URL=https://restful-booker.herokuapp.com
BOOKER_USER=admin
BOOKER_PASSWORD=password123

# Per-request SLA used by response-time assertions (milliseconds)
MAX_RESPONSE_MS=2000
