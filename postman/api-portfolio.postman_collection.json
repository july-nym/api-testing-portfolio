{
  "info": {
    "name": "API Portfolio - jsonplaceholder + restful-booker",
    "description": "Smoke + CRUD coverage across jsonplaceholder (user reads + post writes) and restful-booker (auth + booking lifecycle). Both targets are keyless, so this runs headless under Newman in CI with no secrets. Variables resolve from the selected environment file.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "bookingId", "value": "" }
  ],
  "item": [
    {
      "name": "jsonplaceholder - users & posts",
      "item": [
        {
          "name": "Get single user + schema check",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('responds under SLA', () => pm.expect(pm.response.responseTime).to.be.below(Number(pm.environment.get('maxResponseMs'))));",
                  "const userSchema = {",
                  "  type: 'object',",
                  "  required: ['id', 'name', 'username', 'email', 'address', 'company'],",
                  "  properties: {",
                  "    id: { type: 'integer' },",
                  "    name: { type: 'string' },",
                  "    username: { type: 'string' },",
                  "    email: { type: 'string' },",
                  "    address: { type: 'object' },",
                  "    company: { type: 'object' }",
                  "  }",
                  "};",
                  "pm.test('matches user schema', () => pm.response.to.have.jsonSchema(userSchema));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{jsonplaceholderBaseUrl}}/users/2",
              "host": ["{{jsonplaceholderBaseUrl}}"],
              "path": ["users", "2"]
            }
          }
        },
        {
          "name": "Create post",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const created = pm.response.json();",
                  "pm.test('echoes the title we sent', () => pm.expect(created.title).to.eql('Regression sign-off checklist'));",
                  "pm.test('assigns id 101', () => pm.expect(created.id).to.eql(101));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Regression sign-off checklist\",\n  \"body\": \"Smoke green, schema stable, no P1 regressions.\",\n  \"userId\": 7\n}"
            },
            "url": {
              "raw": "{{jsonplaceholderBaseUrl}}/posts",
              "host": ["{{jsonplaceholderBaseUrl}}"],
              "path": ["posts"]
            }
          }
        },
        {
          "name": "Unknown user returns 404 (negative)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{jsonplaceholderBaseUrl}}/users/999",
              "host": ["{{jsonplaceholderBaseUrl}}"],
              "path": ["users", "999"]
            }
          }
        }
      ]
    },
    {
      "name": "restful-booker - lifecycle",
      "item": [
        {
          "name": "Auth - get token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const token = pm.response.json().token;",
                  "pm.test('token returned', () => pm.expect(token).to.be.a('string'));",
                  "pm.environment.set('bookerToken', token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{bookerUser}}\",\n  \"password\": \"{{bookerPassword}}\"\n}"
            },
            "url": {
              "raw": "{{bookerBaseUrl}}/auth",
              "host": ["{{bookerBaseUrl}}"],
              "path": ["auth"]
            }
          }
        },
        {
          "name": "Create booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('returns a booking id', () => pm.expect(body.bookingid).to.be.a('number'));",
                  "pm.test('persists firstname', () => pm.expect(body.booking.firstname).to.eql('Mariana'));",
                  "// carry the id through update + delete",
                  "pm.collectionVariables.set('bookingId', body.bookingid);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"Mariana\",\n  \"lastname\": \"Okafor\",\n  \"totalprice\": 845,\n  \"depositpaid\": true,\n  \"bookingdates\": {\n    \"checkin\": \"2026-09-12\",\n    \"checkout\": \"2026-09-19\"\n  },\n  \"additionalneeds\": \"Late checkout\"\n}"
            },
            "url": {
              "raw": "{{bookerBaseUrl}}/booking",
              "host": ["{{bookerBaseUrl}}"],
              "path": ["booking"]
            }
          }
        },
        {
          "name": "Update booking (auth required)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('price was updated', () => pm.expect(pm.response.json().totalprice).to.eql(1290));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "token={{bookerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"Mariana\",\n  \"lastname\": \"Okafor\",\n  \"totalprice\": 1290,\n  \"depositpaid\": false,\n  \"bookingdates\": {\n    \"checkin\": \"2026-09-12\",\n    \"checkout\": \"2026-09-19\"\n  },\n  \"additionalneeds\": \"Late checkout\"\n}"
            },
            "url": {
              "raw": "{{bookerBaseUrl}}/booking/{{bookingId}}",
              "host": ["{{bookerBaseUrl}}"],
              "path": ["booking", "{{bookingId}}"]
            }
          }
        },
        {
          "name": "Delete booking + confirm gone",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// booker answers 201 to a successful delete (a known quirk)",
                  "pm.test('delete acknowledged (201)', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Cookie", "value": "token={{bookerToken}}" }],
            "url": {
              "raw": "{{bookerBaseUrl}}/booking/{{bookingId}}",
              "host": ["{{bookerBaseUrl}}"],
              "path": ["booking", "{{bookingId}}"]
            }
          }
        }
      ]
    }
  ]
}
