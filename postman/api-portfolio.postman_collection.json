{
  "info": {
    "name": "API Portfolio - reqres + restful-booker",
    "description": "Smoke + CRUD coverage across reqres (auth/users) and restful-booker (booking lifecycle). Designed to run headless under Newman in CI. Variables resolve from the selected environment file.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "bookingId", "value": "" }
  ],
  "item": [
    {
      "name": "reqres - auth",
      "item": [
        {
          "name": "Login (seeded account)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('responds under SLA', () => pm.expect(pm.response.responseTime).to.be.below(Number(pm.environment.get('maxResponseMs'))));",
                  "const body = pm.response.json();",
                  "pm.test('token is present', () => pm.expect(body.token).to.be.a('string').and.not.empty);",
                  "// stash the token for any downstream request that needs it",
                  "pm.environment.set('reqresToken', body.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{reqresApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"eve.holt@reqres.in\",\n  \"password\": \"cityslicka\"\n}"
            },
            "url": {
              "raw": "{{reqresBaseUrl}}/login",
              "host": ["{{reqresBaseUrl}}"],
              "path": ["login"]
            }
          }
        },
        {
          "name": "Login - missing password (negative)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 400', () => pm.response.to.have.status(400));",
                  "pm.test('error explains the cause', () => pm.expect(pm.response.json().error).to.eql('Missing password'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{reqresApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"peter.holt@reqres.in\"\n}"
            },
            "url": {
              "raw": "{{reqresBaseUrl}}/login",
              "host": ["{{reqresBaseUrl}}"],
              "path": ["login"]
            }
          }
        }
      ]
    },
    {
      "name": "reqres - users",
      "item": [
        {
          "name": "Get single user + schema check",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const userSchema = {",
                  "  type: 'object',",
                  "  required: ['data'],",
                  "  properties: {",
                  "    data: {",
                  "      type: 'object',",
                  "      required: ['id', 'email', 'first_name', 'last_name', 'avatar'],",
                  "      properties: {",
                  "        id: { type: 'integer' },",
                  "        email: { type: 'string' },",
                  "        first_name: { type: 'string' },",
                  "        last_name: { type: 'string' },",
                  "        avatar: { type: 'string' }",
                  "      }",
                  "    }",
                  "  }",
                  "};",
                  "pm.test('matches user schema', () => pm.response.to.have.jsonSchema(userSchema));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "x-api-key", "value": "{{reqresApiKey}}" }],
            "url": {
              "raw": "{{reqresBaseUrl}}/users/2",
              "host": ["{{reqresBaseUrl}}"],
              "path": ["users", "2"]
            }
          }
        },
        {
          "name": "Create user",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const created = pm.response.json();",
                  "pm.test('echoes the job we sent', () => pm.expect(created.job).to.eql('QA Lead'));",
                  "pm.test('assigns an id', () => pm.expect(created.id).to.exist);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{reqresApiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sofia Marchetti\",\n  \"job\": \"QA Lead\"\n}"
            },
            "url": {
              "raw": "{{reqresBaseUrl}}/users",
              "host": ["{{reqresBaseUrl}}"],
              "path": ["users"]
            }
          }
        }
      ]
    },
    {
      "name": "restful-booker - lifecycle",
      "item": [
        {
          "name": "Auth - get token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const token = pm.response.json().token;",
                  "pm.test('token returned', () => pm.expect(token).to.be.a('string'));",
                  "pm.environment.set('bookerToken', token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{bookerUser}}\",\n  \"password\": \"{{bookerPassword}}\"\n}"
            },
            "url": {
              "raw": "{{bookerBaseUrl}}/auth",
              "host": ["{{bookerBaseUrl}}"],
              "path": ["auth"]
            }
          }
        },
        {
          "name": "Create booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('returns a booking id', () => pm.expect(body.bookingid).to.be.a('number'));",
                  "pm.test('persists firstname', () => pm.expect(body.booking.firstname).to.eql('Mariana'));",
                  "// carry the id through update + delete",
                  "pm.collectionVariables.set('bookingId', body.bookingid);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"Mariana\",\n  \"lastname\": \"Okafor\",\n  \"totalprice\": 845,\n  \"depositpaid\": true,\n  \"bookingdates\": {\n    \"checkin\": \"2026-09-12\",\n    \"checkout\": \"2026-09-19\"\n  },\n  \"additionalneeds\": \"Late checkout\"\n}"
            },
            "url": {
              "raw": "{{bookerBaseUrl}}/booking",
              "host": ["{{bookerBaseUrl}}"],
              "path": ["booking"]
            }
          }
        },
        {
          "name": "Update booking (auth required)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('price was updated', () => pm.expect(pm.response.json().totalprice).to.eql(1290));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "token={{bookerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"Mariana\",\n  \"lastname\": \"Okafor\",\n  \"totalprice\": 1290,\n  \"depositpaid\": false,\n  \"bookingdates\": {\n    \"checkin\": \"2026-09-12\",\n    \"checkout\": \"2026-09-19\"\n  },\n  \"additionalneeds\": \"Late checkout\"\n}"
            },
            "url": {
              "raw": "{{bookerBaseUrl}}/booking/{{bookingId}}",
              "host": ["{{bookerBaseUrl}}"],
              "path": ["booking", "{{bookingId}}"]
            }
          }
        },
        {
          "name": "Delete booking + confirm gone",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// booker answers 201 to a successful delete (a known quirk)",
                  "pm.test('delete acknowledged (201)', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Cookie", "value": "token={{bookerToken}}" }],
            "url": {
              "raw": "{{bookerBaseUrl}}/booking/{{bookingId}}",
              "host": ["{{bookerBaseUrl}}"],
              "path": ["booking", "{{bookingId}}"]
            }
          }
        }
      ]
    }
  ]
}
