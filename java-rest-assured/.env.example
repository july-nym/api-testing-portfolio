# The Java suite reads config from src/test/resources/config-${env}.properties,
# but honours these environment variables as overrides (handy in CI). Export them
# in your shell or CI secrets store rather than committing a .env here.

JSONPLACEHOLDER_BASE_URL=https://jsonplaceholder.typicode.com
BOOKER_BASE_URL=https://restful-booker.herokuapp.com

# Run profiles:
#   mvn test                 -> dev profile, full suite
#   mvn test -Psmoke         -> smoke group only
#   mvn test -Pstaging -Denv=staging
